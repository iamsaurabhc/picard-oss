# --- Backend (copy to backend/.env) ---
PICARD_DATA_DIR=.picard-data
DATABASE_URL=sqlite:///.picard-data/picard.db

# LLM — OpenAI default
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# LLM — Ollama alternative (comment out OpenAI block, use these instead)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

ENABLE_TIERED_MODELS=false
# SLM_MODEL=gpt-4o-mini
ENABLE_LLM_QUERY_UNDERSTANDING=true
ENABLE_REGEX_NLP=false
ENABLE_SLM_ENTITY_EXTRACT=true
ENABLE_RULE_ENTITY_EXTRACT=false
SLM_ENTITY_MAX_PAGES=5
ENABLE_CONTEXT_RANKER=true
ENABLE_EXCERPT_SELECTOR=true
QUERY_PLANNER_REPAIR_ON_ZERO_HITS=true
ENABLE_CITATION_JUDGE=false
CHAT_RETRIEVAL_POOL_K=24
CHAT_TOP_K=12
CHAT_OVERVIEW_POOL_K=40
CHAT_OVERVIEW_TOP_K=20
CHAT_OVERVIEW_MAX_CHUNKS_PER_PAGE=2
ENABLE_CARP=true
ENABLE_METADATA_LLM=false
PLANNER_RULE_CONFIDENCE=0.9
CARP_MAX_PROXIMITY_TIER=SAME_SECTION
CARP_ALLOW_PARTIAL_DISCLOSURE=false

# LiteParse / OCR (auto-detect digital vs scanned; PaddleOCR for scans)
LITEPARSE_OCR_SERVER_URL=http://localhost:8829/ocr
LITEPARSE_OCR_LANGUAGE=eng
LITEPARSE_DPI_DIGITAL=150
LITEPARSE_DPI_OCR=300
# LITEPARSE_REQUIRE_PADDLEOCR=false

# Eval / test corpus (Phase 2)
# PICARD_TEST_DATABASE_URL=sqlite:///...

# --- Frontend (copy NEXT_PUBLIC line to frontend/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
