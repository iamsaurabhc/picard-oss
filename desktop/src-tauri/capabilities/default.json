{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "picard-supervisor", "sidecar": true }
      ]
    },
    "updater:default"
  ]
}
